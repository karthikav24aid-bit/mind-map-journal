{
    "version": 2,
    "builds": [
        {
            "src": "backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/auth/(.*)",
            "dest": "backend/server.js"
        },
        {
            "src": "/entries(/.*)?",
            "dest": "backend/server.js"
        },
        {
            "src": "/insights",
            "dest": "backend/server.js"
        },
        {
            "src": "/export",
            "dest": "backend/server.js"
        },
        {
            "src": "/health",
            "dest": "backend/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/$1"
        }
    ]
}